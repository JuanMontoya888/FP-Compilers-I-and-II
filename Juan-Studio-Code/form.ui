  <property name="styleSheet">
   <string notr="true">/* --- ESTILOS GENERALES --- */
QWidget {
    background-color: #1e1e1e;
    color: #cccccc;
    font-family: &quot;Segoe UI&quot;, &quot;San Francisco&quot;, sans-serif;
    font-size: 13px;
}

/* --- BARRA SUPERIOR (Menú simulado) --- */
QToolButton {
    background-color: transparent;
    color: #cccccc;
    border: none;
    padding: 6px 12px;
    margin: 2px;
    border-radius: 4px; /* Bordes redondeados sutiles */
}

QToolButton:hover {
    background-color: #3e3e42; /* Gris más claro al pasar el mouse */
    color: #ffffff;
}

/* Quita la flecha por defecto de los menús desplegables */
QToolButton::menu-indicator {
    image: none; 
}

/* --- SPLITTER (Divisor arrastrable) --- */
QSplitter::handle {
    background-color: #1e1e1e;
}
/* Diferenciamos si arrastras vertical u horizontalmente */
QSplitter::handle:horizontal {
    border-left: 1px solid #252526;
    width: 2px;
}
QSplitter::handle:vertical {
    border-top: 1px solid #252526;
    height: 2px;
}
QSplitter::handle:hover {
    background-color: #007acc; /* Azul VS Code al pasar el mouse */
}

/* --- BARRA LATERAL (Project Explorer) --- */
/* ¡CORREGIDO A QTreeView! */
QTreeView {
    background-color: #252526; /* Un tono ligeramente distinto al editor */
    color: #cccccc;
    border: none;
    outline: none; /* Quita el borde punteado horrible de Windows al hacer clic */
}

QTreeView::item {
    padding: 4px;
    border-radius: 3px;
}

QTreeView::item:hover {
    background-color: #2a2d2e;
    color: #ffffff;
}

QTreeView::item:selected {
    background-color: #37373d;
    color: #ffffff;
}

/* --- PESTAÑAS (QTabWidget) --- */
QTabWidget::pane {
    border: none;
    background-color: #1e1e1e;
}

QTabBar::tab {
    background-color: #2d2d2d;
    color: #858585;
    padding: 8px 20px;
    border: none;
    border-right: 1px solid #1e1e1e; /* Separador entre pestañas */
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #ffffff;
    border-top: 2px solid #007acc; /* Línea azul en la pestaña activa */
}

QTabBar::tab:hover:!selected {
    background-color: #333333;
    color: #cccccc;
}

/* --- EDITOR DE CÓDIGO --- */
QPlainTextEdit {
    background-color: #1e1e1e;
    color: #d4d4d4;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 14px;
    border: none;
    padding: 5px;
    selection-background-color: #264f78; /* Color azul transparente al seleccionar texto */
}

/* --- SCROLLBARS NIVEL DIOS --- */
QScrollBar:vertical, QScrollBar:horizontal {
    border: none;
    background: transparent; /* Fondo invisible */
    width: 12px;
    height: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #424242;
    border-radius: 5px; /* Scrollbars redondeados */
    min-height: 20px;
    min-width: 20px;
    margin: 2px; /* Margen para que floten y no toquen el borde */
}

QScrollBar::handle:vertical:hover, QScrollBar::handle:horizontal:hover {
    background: #4f4f4f; 
}

/* Ocultamos las flechitas de los extremos (nadie las usa en un IDE moderno) */
QScrollBar::add-line, QScrollBar::sub-line {
    background: none;
    border: none;
    height: 0px;
    width: 0px;
}
QScrollBar::add-page, QScrollBar::sub-page {
    background: none;
}</string>
