  <property name="styleSheet">
   <string notr="true">/* --- ESTILOS GENERALES --- */
QWidget {
    background-color: #1e1e1e;
    color: #cccccc;
    font-family: &quot;Segoe UI&quot;, &quot;San Francisco&quot;, sans-serif;
    font-size: 13px;
}

/* --- BARRA SUPERIOR --- */
QToolButton {
    background-color: transparent;
    color: #cccccc;
    border: none;
    padding: 6px 12px;
    margin: 2px;
    border-radius: 4px;
}

QToolButton:hover {
    background-color: #3e3e42;
    color: #ffffff;
}

QToolButton::menu-indicator {
    image: none; 
}

/* --- SPLITTER --- */
QSplitter::handle {
    background-color: #1e1e1e;
}
QSplitter::handle:horizontal {
    border-left: 1px solid #252526;
    width: 2px;
}
QSplitter::handle:vertical {
    border-top: 1px solid #252526;
    height: 2px;
}
QSplitter::handle:hover {
    background-color: #007acc;
}

/* --- BARRA LATERAL (Project Explorer) --- */
QTreeView {
    background-color: #252526;
    color: #cccccc;
    border: none;
    outline: none;
}

QTreeView::item {
    padding: 4px;
    border-radius: 3px;
}

QTreeView::item:hover {
    background-color: #2a2d2e;
    color: #ffffff;
}

QTreeView::item:selected {
    background-color: #37373d;
    color: #ffffff;
}

/* --- PESTAÑAS PRINCIPALES (EDITOR) --- */
QTabWidget::pane {
    border: none;
    background-color: #1e1e1e;
}

QTabBar::tab {
    background-color: #2d2d2d;
    color: #858585;
    padding: 8px 20px;
    border: none;
    border-right: 1px solid #1e1e1e;
}

QTabBar::tab:selected {
    background-color: #1e1e1e;
    color: #ffffff;
    border-top: 2px solid #007acc;
}

QTabBar::tab:hover:!selected {
    background-color: #333333;
    color: #cccccc;
}

/* --- EDITOR DE CÓDIGO --- */
QPlainTextEdit {
    background-color: #1e1e1e;
    color: #d4d4d4;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 14px;
    border: none;
    padding: 5px;
    selection-background-color: #264f78;
}

/* --- PANEL INFERIOR (Terminal y Análisis) --- */
QTabWidget#bottomTabs::pane {
    border: none;
    background-color: #181818;
}

QTabWidget#bottomTabs QTabBar {
    background-color: #1e1e1e;
}

QTabWidget#bottomTabs QTabBar::tab {
    background-color: #2d2d2d;
    color: #858585;
    padding: 5px 15px;
    font-size: 11px;
    border-right: 1px solid #181818;
    border-top: none;
}

QTabWidget#bottomTabs QTabBar::tab:selected {
    background-color: #181818;
    color: white;
    border-bottom: 2px solid #007acc;
}

QTabWidget#bottomTabs QPlainTextEdit {
    background-color: #181818;
    padding: 10px;
}

/* --- SCROLLBARS --- */
QScrollBar:vertical, QScrollBar:horizontal {
    border: none;
    background: transparent;
    width: 12px;
    height: 12px;
    margin: 0px;
}

QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: #424242;
    border-radius: 5px;
    min-height: 20px;
    min-width: 20px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover, QScrollBar::handle:horizontal:hover {
    background: #4f4f4f; 
}

QScrollBar::add-line, QScrollBar::sub-line, QScrollBar::add-page, QScrollBar::sub-page {
    background: none;
    border: none;
    height: 0px;
    width: 0px;
}

/* --- ACTIVITY BAR --- */
QToolButton {
    background-color: transparent;
    border: none;
    padding: 8px;
    border-radius: 4px;
}

QToolButton:hover {
    background-color: #333333; 
}

QToolButton:checked {
    border-left: 2px solid #007acc; 
    background-color: #1e1e1e;
}
/* --- BARRA DE ESTADO DEL EDITOR (Ln, Col, UTF-8) --- */
QWidget#editorStatusBar {
    background-color: #1e1e1e; /* Mismo fondo que el editor de código */
    border-top: 1px solid #2d2d2d; /* Línea divisoria súper fina y elegante */
}

QWidget#editorStatusBar QLabel {
    color: #858585; /* Gris tenue en lugar de blanco para no distraer la vista */
    font-family: &quot;Segoe UI&quot;, &quot;San Francisco&quot;, sans-serif;
    font-size: 11px;
    padding: 2px 6px;
}

QWidget#editorStatusBar QLabel:hover {
    background-color: #2d2d2d; /* Fondo gris sutil al pasar el mouse */
    color: #cccccc; /* El texto se aclara ligeramente para dar feedback interactivo */
    border-radius: 3px;
}</string>
